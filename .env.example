# Copy this file to .env and fill in your values.
# cp .env.example .env
#
# IMPORTANT: PHANTOM_DB_PASSPHRASE is NOT stored here on production.
# It is fed via SSH-mounted tmpfs file (/run/phantom/phantom-secrets.env)
# by scripts/unlock.sh. For local dev only you can export it as an env var.
#
# Never commit .env to version control.

# ─── Upstream Inference Gateway ──────────────────────────────────────────────
# Phala Network's Redpill gateway (api.redpill.ai). Get a key at:
# https://dashboard.redpill.ai
# Legacy PHALA_API_KEY / PHALA_API_BASE still accepted as fallback.
REDPILL_API_KEY=sk-replace-me
REDPILL_API_BASE=https://api.redpill.ai/v1

# ─── Database ────────────────────────────────────────────────────────────────
# SQLCipher passphrase. FOR LOCAL DEV ONLY — on VPS this is fed via tmpfs.
# Generate: openssl rand -hex 32
# On VPS: do not set here; use scripts/unlock.sh instead.
# PHANTOM_DB_PASSPHRASE is intentionally absent from this file for production.
# For local dev only:
# PHANTOM_DB_PASSPHRASE=devonly-replace-me

# Path to SQLCipher database file.
# On VPS: /opt/phantom-api/data/phantom.db (on LUKS-encrypted partition)
DB_PATH=data/phantom.db

# ─── Payment Rail ─────────────────────────────────────────────────────────────
# Selects which payment rail(s) handle new purchases:
#   legacy_xmr   - operator-PC wallet over Tor (direct XMR, no PSP)
#   nowpayments  - NowPayments PSP only (multi-crypto)
#   monero_pay   - MoneroPay daemon only (XMR direct, zero PSP)
#   hybrid       - MoneroPay (XMR) + NowPayments (other coins). RECOMMENDED.
PAYMENT_PROVIDER=hybrid

# Public base URL phantom advertises (used in IPN callbacks + purchase QR).
# Replace your-domain.com with your actual domain.
PUBLIC_BASE_URL=https://api.your-domain.com

# ─── NowPayments (required for nowpayments + hybrid modes) ───────────────────
# Sign up at https://nowpayments.io — they KYC the operator, not the buyer.
NP_API_KEY=
NP_IPN_SECRET=
NP_BASE=https://api.nowpayments.io/v1
# Currency operator receives payouts in (recommended: xmr for max privacy)
NP_PAYOUT_CURRENCY=xmr

# ─── MoneroPay daemon (required for monero_pay + hybrid modes) ───────────────
# Self-hosted MoneroPay daemon running alongside monero-wallet-rpc on operator PC.
# Set to http://<onion>:5000 to route over Tor, or http://127.0.0.1:5000 for local dev.
# See: https://moneropay.eu
MONEROPAY_URL=http://127.0.0.1:5000

# ─── Legacy Monero Wallet RPC (required for legacy_xmr mode) ─────────────────
# Operator-PC wallet exposed via Tor hidden service.
# See pc-side/torrc.example for how to configure the hidden service.
# WALLET_RPC_HOST: set to your .onion hostname for production; 127.0.0.1 for local dev.
WALLET_RPC_HOST=127.0.0.1
WALLET_RPC_PORT=18083
WALLET_RPC_USER=phantom
# Generate: openssl rand -hex 24
WALLET_RPC_PASSWORD=replace-with-openssl-rand-hex-24

# Local Tor SOCKS proxy on VPS (routes wallet RPC calls + MoneroPay over Tor).
TOR_SOCKS_URL=socks5://127.0.0.1:9050

# ─── Multi-crypto Surcharge ────────────────────────────────────────────────────
# Surcharge applied when customer pays via NowPayments (non-XMR coins), as a
# percentage of the sticker price. Covers PSP fee (~1%), XMR conversion (~0.5%),
# rate volatility (~0.5%), and refund buffer. Default 5 = customer pays 1.05x.
# Set to 0 to absorb all fees yourself (margin hit).
MULTI_CRYPTO_SURCHARGE_PERCENT=5

# ─── Budget Ceiling ────────────────────────────────────────────────────────────
# Refuse new purchases if total outstanding customer credit + pending bundle
# credit would exceed this value (USD). Keep at or below your Redpill balance
# to ensure you can always honor outstanding credit.
# Legacy PHALA_BUDGET_USD still accepted as fallback.
REDPILL_BUDGET_USD=1000

# ─── Custom-amount Purchase Bounds ────────────────────────────────────────────
# Min prevents subaddress-spam; max limits AML profile.
CUSTOM_MIN_USD=1
CUSTOM_MAX_USD=1000
CUSTOM_VALIDITY_DAYS=90

# ─── Markup ────────────────────────────────────────────────────────────────────
# Markup over upstream wholesale per-million-token rates.
# MARKUP_TEE_PERCENT: applied to phala/* models (TEE-attested inference).
# MARKUP_PROXY_PERCENT: applied to openai/*, anthropic/*, google/* etc. (gateway only).
# Legacy MARKUP_PERCENT still accepted; applies to both tiers if new vars unset.
MARKUP_PERCENT=30
MARKUP_TEE_PERCENT=30
MARKUP_PROXY_PERCENT=50

# ─── Hot/Cold Wallet Sweep ─────────────────────────────────────────────────────
# COLD_ADDRESS: your mainnet XMR cold wallet address (starts with 4 or 8, 95-106 chars).
# Hot wallet sweeps excess funds to this address when balance crosses the threshold.
# Run scripts/sweep-hot.py or scripts/sweep.py on operator PC.
COLD_ADDRESS=
HOT_SWEEP_THRESHOLD_USD=30
HOT_SWEEP_THRESHOLD_XMR=0.5

# ─── Reload Alert (ntfy.sh push notification) ─────────────────────────────────
# Sends a push notification when estimated Redpill balance drops below alert threshold.
# Topic is a private ntfy.sh channel you control — keep it secret.
# Generate topic: python3 -c "import secrets; print('phantom-reload-' + secrets.token_urlsafe(8).lower())"
REDPILL_NTFY_TOPIC=phantom-reload-changeme
REDPILL_RELOAD_ALERT_USD=10
REDPILL_RELOAD_CHUNK_USD=30

# ─── Dynamic Model Catalog ─────────────────────────────────────────────────────
# On-disk cache of live Redpill model catalog. Survives restarts so phantom serves
# even if Redpill is unreachable on boot.
CATALOG_CACHE_PATH=/opt/phantom-api/data/catalog-cache.json
# How often to refresh from Redpill (seconds). Default 3600 = 1 hour.
CATALOG_REFRESH_SECONDS=3600
# Comma-separated model IDs to suppress from /v1/models even if Redpill ships them.
# Used to deduplicate upstream synonyms (e.g. moonshotai/kimi-k2.6 vs phala/kimi-k2.6).
CATALOG_BLOCKLIST=

# ─── Deployment Helpers ────────────────────────────────────────────────────────
# OPERATOR_USER: the non-root sudo user created by setup-vps.sh on the VPS.
OPERATOR_USER=operator

# PHANTOM_SSH: SSH alias for the VPS (as configured in ~/.ssh/config).
# Used by scripts/deploy.sh.
PHANTOM_SSH=phantom

# PHANTOM_DROPLET_ID: DigitalOcean droplet ID for scripts/deploy.sh snapshot feature.
# Find with: doctl compute droplet list
PHANTOM_DROPLET_ID=

# PHANTOM_DOMAIN: domain used in scripts/deploy.sh health check verify step.
# Replace with your own domain.
PHANTOM_DOMAIN=your-domain.com

# ─── Optional / advanced ─────────────────────────────────────────────────────

# PHANTOM_DEV=1
# Dev only. Tells main.py to serve frontend/ via FastAPI's StaticFiles.
# Production setups use Caddy for frontend; leave unset on VPS.

# Background alert poller (scripts/reload-alert.py). Pushes a ntfy.sh
# notification when estimated Redpill balance crosses a threshold.
REDPILL_NTFY_BASE=https://ntfy.sh
REDPILL_STATE_FILE=/opt/phantom-api/data/redpill-alert.state.json
REDPILL_ALERT_COOLDOWN_HOURS=6

# Encrypted DB backup script (scripts/backup-db.py).
PHANTOM_BACKUP_DIR=/opt/phantom-api/backups
PHANTOM_BACKUP_KEEP=30

# Operator-PC sweep script (scripts/sweep.py runs on your home PC, NOT VPS).
# LOCAL_WALLET_RPC: URL of monero-wallet-rpc on your PC.
# SWEEP_THRESHOLD_XMR: only sweep when balance exceeds this.
# LOCAL_WALLET_RPC=http://127.0.0.1:18083/json_rpc
# SWEEP_THRESHOLD_XMR=0.5
