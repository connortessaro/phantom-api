# Copy to .env on VPS. NEVER commit .env.
# PHANTOM_DB_PASSPHRASE is NOT here — fed via tmpfs at /run/phantom/phantom-secrets.env

# Upstream gateway: Phala Network's Redpill (api.redpill.ai). The model-ID
# prefix `phantom/*` is a capability tag meaning "runs in Phala TEE enclave",
# not a brand. Legacy PHALA_API_KEY / PHALA_API_BASE still accepted.
REDPILL_API_BASE=https://api.redpill.ai/v1
REDPILL_API_KEY=sk-replace-me

# DB path (sits on encrypted partition; SQLCipher passphrase fed via tmpfs)
DB_PATH=/opt/phantom-api/data/phantom.db

# Capacity ceiling — refuse new purchases once total outstanding credit + pending
# bundle credit would exceed this many USD. Operator must keep Redpill account
# balance >= this value at all times.
REDPILL_BUDGET_USD=1000

# Custom-amount purchase bounds.
CUSTOM_MIN_USD=10
CUSTOM_MAX_USD=1000
CUSTOM_VALIDITY_DAYS=90

# Markup over upstream wholesale, in percent.
# 30 = customer pays 1.30× wholesale for TEE-tier models.
# Proxy-tier models (Claude/GPT/Gemini/Grok) carry MARKUP_PROXY_PERCENT (default 50).
MARKUP_PERCENT=30
# MARKUP_TEE_PERCENT=30
# MARKUP_PROXY_PERCENT=50

# Reload alert (ntfy.sh push when estimated Redpill balance crosses threshold).
# Generate topic via: python3 -c "import secrets; print('phantom-reload-' + secrets.token_urlsafe(8).lower())"
REDPILL_NTFY_TOPIC=phantom-reload-changeme
REDPILL_RELOAD_ALERT_USD=10
REDPILL_RELOAD_CHUNK_USD=30

# ─── Payment rail (NowPayments) ──────────────────────────────────────────────
# Phantom routes ALL purchases through NowPayments (PSP). Customer picks
# XMR-locked checkout (0% surcharge) or multi-crypto checkout (+5% surcharge)
# via the `rail` field on POST /v1/purchase. NowPayments handles deposit
# address generation, conversion, and payout to your XMR wallet.
#
# Setup steps:
#   1. Create a NowPayments merchant account: https://nowpayments.io
#   2. Verify (operator KYC; customer never KYCs).
#   3. Settings → Payments → Payment markup = 0%.
#   4. Settings → Payments → Withdrawal fee paid by = Sender.
#   5. Settings → Payments → Wrong-asset deposits = Do not process.
#   6. Settings → Payments → Default payment status = Partially Paid.
#   7. Settings → Notifications → Webhook URL = https://<your-domain>/v1/nowpayments/ipn
#   8. Copy your API key + IPN secret here.
NP_API_KEY=
NP_IPN_SECRET=
NP_BASE=https://api.nowpayments.io/v1
NP_PAYOUT_CURRENCY=xmr

# Multi-crypto surcharge (% on top of sticker for BTC/ETH/USDT/etc.). Covers
# NowPayments service fee + XMR auto-conversion + rate volatility buffer.
# Customers paying XMR direct (rail=xmr) bypass this entirely.
MULTI_CRYPTO_SURCHARGE_PERCENT=5

# Public base URL phantom advertises. Must be reachable from NowPayments.
PUBLIC_BASE_URL=https://your-domain.com

# ─── Optional / advanced ─────────────────────────────────────────────────────

# Dev only: serve frontend/ via FastAPI (production uses Caddy).
# PHANTOM_DEV=1

# Encrypted DB backup (scripts/backup-db.py).
PHANTOM_BACKUP_DIR=/opt/phantom-api/backups
PHANTOM_BACKUP_KEEP=30

# Reload-alert state file + cooldown.
# REDPILL_NTFY_BASE=https://ntfy.sh
# REDPILL_STATE_FILE=/opt/phantom-api/data/redpill-alert.state.json
# REDPILL_ALERT_COOLDOWN_HOURS=6

# Catalog cache + refresh.
# CATALOG_CACHE_PATH=/opt/phantom-api/data/catalog-cache.json
# CATALOG_REFRESH_SECONDS=3600
# CATALOG_BLOCKLIST=

# Deploy script targets.
# OPERATOR_USER=connor
# PHANTOM_SSH=phantom
# PHANTOM_DROPLET_ID=
# PHANTOM_DOMAIN=your-domain.com
